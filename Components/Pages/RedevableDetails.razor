@page "/redevable-details/{Id:int}"
@using ART122.Data
@using ART122.Services
@inject IRedevableService RedevableService
@inject IImpotService ImpotService
@inject INatureImpotService NatureService
@inject IDeclarationService DeclarationService

@if (redevable == null)
{
    <div class="text-center mt-5">
        <div class="spinner-border text-primary"></div>
    </div>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="mb-0">
            <span class="text-muted fw-normal">Redevable /</span>
            @redevable.FullName
        </h4>
        <a href="/redevables" class="btn btn-outline-secondary btn-sm">← Retour</a>
    </div>

    <div class="row g-3">

        @* ── Identity card ────────────────────────────────────────────────── *@
        <div class="col-md-6">
            <div class="card h-100 shadow-sm">
                <div class="card-header fw-semibold bg-dark text-white">
                    👤 Informations du Redevable
                </div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-5">Nom complet</dt>
                        <dd class="col-7">@redevable.FullName</dd>

                        @if (!string.IsNullOrWhiteSpace(redevable.FilsDe))
                        {
                            <dt class="col-5">Fils de</dt>
                            <dd class="col-7">@redevable.FilsDe</dd>
                        }

                        <dt class="col-5">BP</dt>
                        <dd class="col-7">@redevable.BP</dd>

                        <dt class="col-5">Article</dt>
                        <dd class="col-7">@redevable.Article</dd>

                        <dt class="col-5">NIF</dt>
                        <dd class="col-7">@redevable.NIF</dd>

                        <dt class="col-5">Activité</dt>
                        <dd class="col-7">@redevable.Activite</dd>

                        @if (!string.IsNullOrWhiteSpace(redevable.Etablissement))
                        {
                            <dt class="col-5">Etablissement</dt>
                            <dd class="col-7">@redevable.Etablissement</dd>
                        }

                        <dt class="col-5">Adresse</dt>
                        <dd class="col-7">@redevable.Adresse</dd>

                        <dt class="col-5">Téléphone</dt>
                        <dd class="col-7">@redevable.Telephone</dd>

                        @if (!string.IsNullOrWhiteSpace(redevable.Email))
                        {
                            <dt class="col-5">Email</dt>
                            <dd class="col-7">@redevable.Email</dd>
                        }
                    </dl>
                </div>
            </div>
        </div>

        @* ── Declaration card ─────────────────────────────────────────────── *@
        <div class="col-md-6">
            <div class="card h-100 shadow-sm">
                <div class="card-header fw-semibold @(declaration is null ? "bg-secondary" : "bg-primary") text-white">
                    📋 تصريح الاكتتاب — Art.122
                </div>
                <div class="card-body">
                    @if (declaration is null)
                    {
                        <div class="text-muted fst-italic">
                            لم يتم تسجيل أي تصريح بعد.
                        </div>
                    }
                    else
                    {
                        <dl class="row mb-0">
                            <dt class="col-6">رقم التصريح</dt>
                            <dd class="col-6">
                                <span class="badge bg-primary fs-6">
                                    @declaration.Number
                                </span>
                            </dd>

                            <dt class="col-6">تاريخ التصريح</dt>
                            <dd class="col-6">
                                @declaration.Date.ToString("dd/MM/yyyy")
                            </dd>

                            <dt class="col-6">كيفية التسديد</dt>
                            <dd class="col-6">
                                @if (declaration.DafaaWahida)
                                {
                                    <span class="badge bg-success">دفعة واحدة</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">
                                        على أقساط
                                        (@declaration.Versements.Count قسط)
                                    </span>
                                }
                            </dd>

                            <dt class="col-6">الحقوق البسيطة</dt>
                            <dd class="col-6">@Fmt(declaration.Droit)</dd>

                            <dt class="col-6">غرامات الوعاء</dt>
                            <dd class="col-6">@Fmt(declaration.PA)</dd>

                            <dt class="col-6">غرامات التحصيل</dt>
                            <dd class="col-6">@Fmt(declaration.PR)</dd>

                            <dt class="col-6 border-top pt-2 fw-bold">
                                المبلغ الإجمالي
                            </dt>
                            <dd class="col-6 border-top pt-2 fw-bold text-danger">
                                @Fmt(declaration.MontantTotal)
                            </dd>

                            <dt class="col-6 fw-bold">المتبقي (70%)</dt>
                            <dd class="col-6 fw-bold text-success">
                                @Fmt(declaration.MontantRestant)
                            </dd>

                            <dt class="col-6">التخفيض (30%)</dt>
                            <dd class="col-6">
                                @Fmt(declaration.Droit * 0.30m)
                            </dd>
                        </dl>
                    }
                </div>
            </div>
        </div>

        @* ── Versements (only when على أقساط) ────────────────────────────── *@
        @* ── Versements (only when على أقساط) ────────────────────────────── *@
        @if (declaration is { AlaAqsat: true } && declaration.Versements.Any())
        {
            <div class="col-12">
                <div class="card shadow-sm">
                    <div class="card-header fw-semibold bg-warning text-dark">
                        📅 جدول الأقساط
                        <span class="badge bg-dark ms-2">
                            @declaration.Versements.Count أقساط
                        </span>
                    </div>
                    <div class="card-body p-0">
                        <table class="table table-hover table-sm mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th style="width:50px;">#</th>
                                    <th>تاريخ الاستحقاق</th>
                                    <th class="text-end">المبلغ (دج)</th>
                                    <th>رقم الوصل</th>
                                    <th>تاريخ الدفع</th>
                                    <th>الحالة</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var v in declaration.Versements.OrderBy(v => v.NumeroOrdre))
                                {
                                    var isPaid = v.EstPaye;
                                    var isDue =  !isPaid;
                                    var isLate = v.DatePrevue.Date < DateTime.Today && !isPaid;
                                    var isPaying = payingVersementId == v.Id;

                                    <tr class="@(isLate ? "table-danger" : isPaid ? "table-success" : "")">
                                        <td class="text-center fw-bold">@v.NumeroOrdre</td>
                                        <td>@v.DatePrevue.ToString("dd/MM/yyyy")</td>
                                        <td class="text-end fw-semibold">@Fmt(v.Montant)</td>
                                        <td>
                                            @if (isPaid)
                                            {
                                                <span class="badge bg-success">@v.NumeroQuittance</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">—</span>
                                            }
                                        </td>
                                        <td>
                                            @if (v.DatePaiement.HasValue)
                                            {
                                                @v.DatePaiement.Value.ToString("dd/MM/yyyy")
                                            }
                                            else
                                            {
                                                <span class="text-muted">—</span>
                                            }
                                        </td>
                                        <td>
                                            @if (isPaid)
                                            {
                                                <span class="badge bg-success">✅ مدفوع</span>
                                            }
                                            else if (isLate)
                                            {
                                                <span class="badge bg-danger">⚠️ متأخر</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">⏳ قيد الانتظار</span>
                                            }
                                        </td>
                                        <td>
                                            @if (isDue && !isPaying)
                                            {
                                                <button class="btn btn-sm btn-primary"
                                                        @onclick="() => StartPay(v.Id)">
                                                    💳 Payer
                                                </button>
                                            }
                                            else if (isPaying)
                                            {
                                                <button class="btn btn-sm btn-outline-secondary"
                                                        @onclick="CancelPay">
                                                    ✕
                                                </button>
                                            }
                                        </td>
                                    </tr>

                                    @* ── Inline payment form ── *@
                                    @if (isPaying)
                                    {
                                        <tr class="table-info">
                                            <td colspan="7">
                                                <div class="d-flex align-items-end gap-3 p-2 flex-wrap">
                                                    <div>
                                                        <label class="form-label small mb-1">
                                                            رقم الوصل <span class="text-danger">*</span>
                                                        </label>
                                                        <input class="form-control form-control-sm"
                                                               style="min-width:180px;"
                                                               placeholder="Q-2026-001"
                                                               @bind="payQuittance" />
                                                    </div>
                                                    <div>
                                                        <label class="form-label small mb-1">تاريخ الدفع</label>
                                                        <input type="date" class="form-control form-control-sm"
                                                               @bind="payDate" />
                                                    </div>
                                                    <button class="btn btn-success btn-sm"
                                                            disabled="@string.IsNullOrWhiteSpace(payQuittance)"
                                                            @onclick="ConfirmPay">
                                                        ✅ تأكيد
                                                    </button>
                                                    @if (!string.IsNullOrEmpty(payError))
                                                    {
                                                        <span class="text-danger small">@payError</span>
                                                    }
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                            <tfoot class="table-secondary fw-bold">
                                <tr>
                                    <td colspan="2" class="text-end">Total</td>
                                    <td class="text-end">
                                        @Fmt(declaration.Versements.Sum(v => v.Montant))
                                    </td>
                                    <td colspan="4"></td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            </div>
        }
        @* ── DG Decision card ────────────────────────────────────────────────── *@
        @if (declaration is not null)
        {
            <div class="col-12">
                <div class="card shadow-sm border-2 @DGCardBorder">
                    <div class="card-header fw-semibold @DGCardHeader text-white d-flex justify-content-between align-items-center">
                        <span>⚖️ قرار المدير العام — Décision DG</span>
                        <span class="badge bg-white @DGBadgeText fs-6">@DGDecisionLabel</span>
                    </div>
                    <div class="card-body">

                        @* ── Already decided — read-only summary ── *@
                        @if (declaration.DGDecision != DGDecisionStatus.EnAttente)
                        {
                            <dl class="row mb-0">
                                <dt class="col-md-3">القرار</dt>
                                <dd class="col-md-9">
                                    @if (declaration.DGDecision == DGDecisionStatus.Acceptee)
                                    {
                                        <span class="badge bg-success fs-6">✅ مقبول</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger fs-6">❌ مرفوض</span>
                                    }
                                </dd>

                                <dt class="col-md-3">تاريخ القرار</dt>
                                <dd class="col-md-9">
                                    @declaration.DGDecisionDate?.ToString("dd/MM/yyyy")
                                </dd>

                                <dt class="col-md-3">رقم القرار</dt>
                                <dd class="col-md-9">@declaration.DGDecisionReference</dd>

                                @if (!string.IsNullOrWhiteSpace(declaration.DGDecisionNote))
                                {
                                    <dt class="col-md-3">ملاحظات</dt>
                                    <dd class="col-md-9">@declaration.DGDecisionNote</dd>
                                }

                                @if (declaration.DGDecision == DGDecisionStatus.Acceptee)
                                {
                                    <dt class="col-md-3 border-top pt-2">إلغاء غرامات الوعاء (PA)</dt>
                                    <dd class="col-md-9 border-top pt-2 text-success fw-bold">
                                        @Fmt(declaration.AlghaPA)
                                    </dd>

                                    <dt class="col-md-3">إلغاء غرامات التحصيل (PR)</dt>
                                    <dd class="col-md-9 text-success fw-bold">
                                        @Fmt(declaration.AlghaPR)
                                    </dd>

                                    <dt class="col-md-3 fw-bold">إجمالي الإلغاء</dt>
                                    <dd class="col-md-9 fw-bold text-success fs-5">
                                        @Fmt(declaration.AlghaPA + declaration.AlghaPR)
                                    </dd>
                                }
                            </dl>

                            <button class="btn btn-sm btn-outline-secondary mt-3"
                                    @onclick="() => dgEditing = true">
                                ✏️ تعديل القرار
                            </button>
                        }

                        @* ── Pending or editing — input form ── *@
                        @if (declaration.DGDecision == DGDecisionStatus.EnAttente || dgEditing)
                        {
                            <div class="row g-3">

                                @* Decision radio *@
                                <div class="col-12">
                                    <label class="form-label fw-semibold">القرار</label>
                                    <div class="d-flex gap-4">
                                        <div class="form-check">
                                            <input class="form-check-input" type="radio"
                                                   name="dgDecision" id="dgAccept"
                                                   checked="@(dgDecision == DGDecisionStatus.Acceptee)"
                                                   @onchange="() => dgDecision = DGDecisionStatus.Acceptee" />
                                            <label class="form-check-label text-success fw-semibold" for="dgAccept">
                                                ✅ مقبول
                                            </label>
                                        </div>
                                        <div class="form-check">
                                            <input class="form-check-input" type="radio"
                                                   name="dgDecision" id="dgRefuse"
                                                   checked="@(dgDecision == DGDecisionStatus.Refusee)"
                                                   @onchange="() => dgDecision = DGDecisionStatus.Refusee" />
                                            <label class="form-check-label text-danger fw-semibold" for="dgRefuse">
                                                ❌ مرفوض
                                            </label>
                                        </div>
                                    </div>
                                </div>

                                @* Date + Reference *@
                                <div class="col-md-4">
                                    <label class="form-label">تاريخ القرار <span class="text-danger">*</span></label>
                                    <input type="date" class="form-control" @bind="dgDecisionDate" />
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">رقم القرار <span class="text-danger">*</span></label>
                                    <input class="form-control" placeholder="DG-2026-001"
                                           @bind="dgDecisionReference" />
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">ملاحظات</label>
                                    <input class="form-control" placeholder="motif / remarques..."
                                           @bind="dgDecisionNote" />
                                </div>

                                @* Accepted: amounts auto-filled from declaration — no manual entry *@
                                @if (dgDecision == DGDecisionStatus.Acceptee)
                                {
                                    <div class="col-12">
                                        <div class="alert alert-success py-2 mb-0 d-flex gap-4 align-items-center">
                                            <span>⚖️ سيتم إلغاء الغرامات تلقائياً عند الحفظ:</span>
                                            <span>غ. الوعاء: <strong>@Fmt(declaration.PA)</strong></span>
                                            <span>غ. التحصيل: <strong>@Fmt(declaration.PR)</strong></span>
                                            <span class="ms-auto fw-bold text-success fs-6">
                                                الإجمالي: @Fmt(declaration.PA + declaration.PR)
                                            </span>
                                        </div>
                                    </div>
                                }

                                @* Error *@
                                @if (!string.IsNullOrEmpty(dgError))
                                {
                                    <div class="col-12">
                                        <div class="alert alert-danger py-2">@dgError</div>
                                    </div>
                                }

                                @* Actions *@
                                <div class="col-12 d-flex gap-2">
                                    <button class="btn btn-primary"
                                            disabled="@(dgSaving || string.IsNullOrWhiteSpace(dgDecisionReference))"
                                            @onclick="SaveDGDecision">
                                        @if (dgSaving)
                                        {
                                            <span class="spinner-border spinner-border-sm me-1"></span>
                                        }
                                        💾 حفظ القرار
                                    </button>
                                    @if (dgEditing)
                                    {
                                        <button class="btn btn-secondary"
                                                @onclick="() => dgEditing = false">
                                            إلغاء
                                        </button>
                                    }
                                </div>

                            </div>
                        }

                    </div>
                </div>
            </div>
        }
        @* ── Add / Edit Impot form ────────────────────────────────────────── *@
        <div class="col-12">
            <div class="card shadow-sm @(declaration is not null ? "opacity-50" : "")">
                <div class="card-header fw-semibold
                                @(declaration is not null ? "bg-secondary" : editMode ? "bg-warning" : "bg-primary")
                                text-white">
                    @if (declaration is not null)
                    {
                        <span>🔒 Add Impot — مسجل مسبقاً، لا يمكن التعديل</span>
                    }
                    else
                    {
                        <span>@(editMode ? "✏️ Edit Impot" : "➕ Add Impot")</span>
                    }
                </div>
                <div class="card-body">
                    @if (declaration is not null)
                    {
                        <div class="alert alert-warning mb-0">
                            ⚠️ هذا المكلف مسجل في السجل برقم التصريح
                            <strong>@declaration.Number</strong>.
                            لا يمكن إضافة أو تعديل الضرائب بعد التسجيل.
                        </div>
                    }
                    else
                    {
                        <div class="row g-3">

                            <div class="col-md-3">
                                <label class="form-label">Nature Impot</label>
                                <select class="form-select"
                                        @bind="currentImpot.NatureImpotId">
                                    <option value="">-- Select Type --</option>
                                    @foreach (var n in natures)
                                    {
                                        <option value="@n.Id">@n.Name</option>
                                    }
                                </select>
                            </div>

                            <div class="col-md-2">
                                <label class="form-label">Year</label>
                                <input type="number" class="form-control"
                                       placeholder="2026"
                                       @bind="currentImpot.YearImpot" />
                            </div>

                            <div class="col-md-3">
                                <label class="form-label">Role Number</label>
                                <input class="form-control"
                                       placeholder="e.g. R-2026-001"
                                       @bind="currentImpot.RoleNumber" />
                            </div>

                            <div class="col-md-2">
                                <label class="form-label">Droit</label>
                                <input type="number" class="form-control"
                                       placeholder="0"
                                       @bind="currentImpot.Droit" />
                            </div>

                            <div class="col-md-2">
                                <label class="form-label">PA</label>
                                <input type="number" class="form-control"
                                       placeholder="0"
                                       @bind="currentImpot.PA" />
                            </div>

                            <div class="col-md-2">
                                <label class="form-label">PR</label>
                                <input type="number" class="form-control"
                                       placeholder="0"
                                       @bind="currentImpot.PR" />
                            </div>

                            <div class="col-md-3 d-flex align-items-end gap-2">
                                <button class="btn btn-success flex-fill"
                                        @onclick="SaveImpot">
                                    @(editMode ? "Update" : "Add")
                                </button>
                                @if (editMode)
                                {
                                    <button class="btn btn-secondary flex-fill"
                                            @onclick="CancelEdit">
                                        Cancel
                                    </button>
                                }
                            </div>

                        </div>
                    }
                </div>
            </div>
        </div>

        @* ── Impots table ─────────────────────────────────────────────────── *@
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header fw-semibold bg-dark text-white">
                    🧾 Impots List
                </div>
                <div class="card-body p-0">
                    @if (!redevable.Impots.Any())
                    {
                        <div class="p-3 text-muted fst-italic">
                            No impots found.
                        </div>
                    }
                    else
                    {
                        <table class="table table-striped table-hover table-sm mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Role</th>
                                    <th>Year</th>
                                    <th class="text-end">Droit</th>
                                    <th class="text-end">PA</th>
                                    <th class="text-end">PR</th>
                                    <th>Nature</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var i in redevable.Impots)
                                {
                                    <tr>
                                        <td>@i.RoleNumber</td>
                                        <td>@i.YearImpot</td>
                                        <td class="text-end">@Fmt(i.Droit)</td>
                                        <td class="text-end">@Fmt(i.PA)</td>
                                        <td class="text-end">@Fmt(i.PR)</td>
                                        <td>@i.NatureImpot?.Name</td>
                                        <td>
                                            @if (declaration is null)
                                            {
                                                <button class="btn btn-sm btn-warning"
                                                        @onclick="() => EditImpot(i)">
                                                    Edit
                                                </button>
                                                <button class="btn btn-sm btn-danger ms-1"
                                                        @onclick="() => DeleteImpot(i.Id)">
                                                    Delete
                                                </button>
                                            }
                                            else
                                            {
                                                <span class="text-muted small">🔒</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot class="table-secondary fw-bold">
                                <tr>
                                    <td colspan="2" class="text-end">Total</td>
                                    <td class="text-end">
                                        @Fmt(redevable.Impots.Sum(i => i.Droit))
                                    </td>
                                    <td class="text-end">
                                        @Fmt(redevable.Impots.Sum(i => i.PA))
                                    </td>
                                    <td class="text-end">
                                        @Fmt(redevable.Impots.Sum(i => i.PR))
                                    </td>
                                    <td colspan="2"></td>
                                </tr>
                            </tfoot>
                        </table>
                    }
                </div>
            </div>
        </div>

    </div>
}

@code {
    [Parameter] public int Id { get; set; }

    RedevableInfo? redevable;
    Declaration? declaration;
    List<NatureImpot> natures = [];

    Impot currentImpot = new();
    bool editMode = false;

    protected override async Task OnInitializedAsync()
    {
        natures = await NatureService.GetAllAsync();
        await Load();
    }

    async Task Load()
    {
        var all = await RedevableService.GetAllAsync();
        redevable = all.FirstOrDefault(x => x.Id == Id);

        var decls = await DeclarationService.GetAllAsync();
        declaration = decls.FirstOrDefault(d => d.RedevableInfoId == Id);
    }

    // ── Impot CRUD (all guarded by declaration check) ──────────────────────────

    async Task SaveImpot()
    {
        if (declaration is not null) return;

        if (editMode)
            await ImpotService.UpdateAsync(currentImpot);
        else
        {
            currentImpot.RedevableInfoId = Id;
            await ImpotService.AddAsync(currentImpot);
        }

        currentImpot = new Impot();
        editMode = false;
        await Load();
    }

    void EditImpot(Impot i)
    {
        if (declaration is not null) return;

        currentImpot = new Impot
        {
            Id = i.Id,
            RoleNumber = i.RoleNumber,
            YearImpot = i.YearImpot,
            PA = i.PA,
            PR = i.PR,
            Droit = i.Droit,
            NatureImpotId = i.NatureImpotId,
            RedevableInfoId = i.RedevableInfoId
        };
        editMode = true;
    }

    async Task DeleteImpot(int id)
    {
        if (declaration is not null) return;

        await ImpotService.DeleteAsync(id);
        await Load();
    }

    void CancelEdit()
    {
        currentImpot = new Impot();
        editMode = false;
    }

    // ── Helpers ────────────────────────────────────────────────────────────────

    static string Fmt(decimal v) =>
        v == 0 ? "—" :
        string.Format("{0:N0}", Math.Round(v, 0, MidpointRounding.AwayFromZero))
              .Replace(",", "\u00A0") + ",00";


    // ── Payment state ──────────────────────────────────────────────────────────

    int? payingVersementId = null;
    string payQuittance = string.Empty;
    DateTime payDate = DateTime.Today;
    string payError = string.Empty;

    void StartPay(int versementId)
    {
        payingVersementId = versementId;
        payQuittance = string.Empty;
        payDate = DateTime.Today;
        payError = string.Empty;
    }

    void CancelPay()
    {
        payingVersementId = null;
        payError = string.Empty;
    }

    async Task ConfirmPay()
    {
        if (payingVersementId is null) return;
        if (string.IsNullOrWhiteSpace(payQuittance))
        {
            payError = "رقم الوصل مطلوب.";
            return;
        }

        try
        {
            await DeclarationService.PayVersementAsync(
                payingVersementId.Value,
                payQuittance,
                payDate);

            payingVersementId = null;
            payError = string.Empty;
            await Load();
        }
        catch (Exception ex)
        {
            payError = ex.Message;
        }
    }

    // ── DG Decision state ──────────────────────────────────────────────────────

    DGDecisionStatus dgDecision = DGDecisionStatus.Acceptee;
    DateTime dgDecisionDate = DateTime.Today;
    string dgDecisionReference = string.Empty;
    string dgDecisionNote = string.Empty;
 
    bool dgSaving = false;
    bool dgEditing = false;
    string dgError = string.Empty;

    async Task SaveDGDecision()
    {
        if (declaration is null) return;
        if (string.IsNullOrWhiteSpace(dgDecisionReference))
        {
            dgError = "رقم القرار مطلوب.";
            return;
        }

        dgSaving = true;
        dgError = string.Empty;

        try
        {
            await DeclarationService.ApplyDGDecisionAsync(
     declaration.Id,
     dgDecision,
     dgDecisionDate,
     dgDecisionReference,
     dgDecisionNote,
     alghaPA: dgDecision == DGDecisionStatus.Acceptee ? declaration.PA : 0,
     alghaPR: dgDecision == DGDecisionStatus.Acceptee ? declaration.PR : 0);

            dgEditing = false;
            await Load();
        }
        catch (Exception ex)
        {
            dgError = ex.Message;
        }
        finally
        {
            dgSaving = false;
        }
    }

    // ── DG card styling helpers ────────────────────────────────────────────────

    string DGCardBorder => declaration?.DGDecision switch
    {
        DGDecisionStatus.Acceptee => "border-success",
        DGDecisionStatus.Refusee => "border-danger",
        _ => "border-warning"
    };

    string DGCardHeader => declaration?.DGDecision switch
    {
        DGDecisionStatus.Acceptee => "bg-success",
        DGDecisionStatus.Refusee => "bg-danger",
        _ => "bg-warning text-dark"  // overrides text-white for yellow
    };

    string DGBadgeText => declaration?.DGDecision switch
    {
        DGDecisionStatus.Acceptee => "text-success",
        DGDecisionStatus.Refusee => "text-danger",
        _ => "text-warning"
    };

    string DGDecisionLabel => declaration?.DGDecision switch
    {
        DGDecisionStatus.Acceptee => "مقبول ✅",
        DGDecisionStatus.Refusee => "مرفوض ❌",
        _ => "⏳ في انتظار القرار"
    };
}
