@page "/redevable-details/{Id:int}"
@using ART122.Data
@using ART122.Services
@inject IRedevableService RedevableService
@inject IImpotService ImpotService
@inject INatureImpotService NatureService
@inject IDeclarationService DeclarationService

@if (redevable == null)
{
    <div class="text-center mt-5">
        <div class="spinner-border text-primary"></div>
        <div class="text-muted mt-2">جارٍ التحميل...</div>
    </div>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="mb-0 fw-bold">
            <span class="text-muted fw-normal small">المكلف /</span>
            @redevable.FullName
        </h4>
        <a href="/redevables" class="btn btn-outline-secondary btn-sm">← العودة للقائمة</a>
    </div>

    <div class="row g-3">

        @* ══ Identity card ════════════════════════════════════════════════════ *@
        <div class="col-md-6">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-header fw-semibold text-white"
                     style="background:linear-gradient(90deg,#003311,#009911); opacity:90%">
                    👤 بيانات المكلف
                </div>
                <div class="card-body">
                    @* ── Table 1 : بيانات المكلف ─────────────────────────────────────────── *@
                    <div class="table-responsive">
                        <table class="table table-sm table-borderless mb-0">
                            <tbody>
                                <tr>
                                    <td class="text-muted fw-semibold" style="width:45%">الاسم الكامل</td>
                                    <td class="fw-bold">@redevable.FullName</td>
                                </tr>

                                @if (!string.IsNullOrWhiteSpace(redevable.FilsDe))
                                {
                                    <tr>
                                        <td class="text-muted fw-semibold">ابن / بنت</td>
                                        <td>@redevable.FilsDe</td>
                                    </tr>
                                }

                                <tr>
                                    <td class="text-muted fw-semibold">رقم BP</td>
                                    <td><span class="badge bg-dark fs-6">@redevable.BP</span></td>
                                </tr>
                                <tr>
                                    <td class="text-muted fw-semibold">رقم المادة</td>
                                    <td>@redevable.Article</td>
                                </tr>
                                <tr>
                                    <td class="text-muted fw-semibold">NIF</td>
                                    <td><span class="font-monospace">@redevable.NIF</span></td>
                                </tr>
                                <tr>
                                    <td class="text-muted fw-semibold">النشاط</td>
                                    <td>@redevable.Activite</td>
                                </tr>

                                @if (!string.IsNullOrWhiteSpace(redevable.Etablissement))
                                {
                                    <tr>
                                        <td class="text-muted fw-semibold">المؤسسة</td>
                                        <td>@redevable.Etablissement</td>
                                    </tr>
                                }

                                <tr>
                                    <td class="text-muted fw-semibold">العنوان</td>
                                    <td>@redevable.Adresse</td>
                                </tr>
                                <tr>
                                    <td class="text-muted fw-semibold">الهاتف</td>
                                    <td>
                                        <a href="tel:@redevable.Telephone" class="text-decoration-none">
                                            📞 @redevable.Telephone
                                        </a>
                                    </td>
                                </tr>

                                @if (!string.IsNullOrWhiteSpace(redevable.Email))
                                {
                                    <tr>
                                        <td class="text-muted fw-semibold">البريد الإلكتروني</td>
                                        <td>
                                            <a href="mailto:@redevable.Email" class="text-decoration-none">
                                                ✉️ @redevable.Email
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    @* ── Table 2 : الوضعية الجبائية ──────────────────────────────────────── *@
                    <div class="mt-3 rounded-3 overflow-hidden border border-1"
                         style="border-color:#dee2e6!important">
                        <div class="px-3 py-2 fw-semibold text-white small"
                             style="background:linear-gradient(90deg,#440011,#770011); opacity:90%">
                            📄 الوضعية الجبائية
                        </div>
                        <table class="table table-sm table-borderless mb-0">
                            <tbody>
                                <tr class="border-bottom">
                                    <td class="text-muted fw-semibold" style="width:55%">
                                        رقم الوضعية الجبائية
                                    </td>
                                    <td>
                                        <span class="badge bg-secondary fs-6">
                                            @redevable.NumExtraitDeRole
                                        </span>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="text-muted fw-semibold">تاريخ الوضعية الجبائية</td>
                                    <td>
                                        <span class="badge bg-light text-dark border fs-6">
                                            📅 @redevable.DateExtraitDeRole.ToString("dd/MM/yyyy")
                                        </span>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        @* ══ Declaration card ═════════════════════════════════════════════════ *@
        <div class="col-md-6">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-header fw-semibold text-white"
                     style="background:@(declaration is null ? "#6c757d" : "linear-gradient(135deg,#0d6efd,#0a58ca)");">
                    📋 تصريح الاكتتاب — المادة 122
                </div>
                <div class="card-body">
                    @* ── Table : تصريح الاكتتاب ─────────────────────────────────────────── *@
                    <div class="card-body">
                        @if (declaration is null)
                        {
                            <div class="text-center py-4">
                                <div style="font-size:2.5rem;">📭</div>
                                <div class="text-muted fst-italic mt-2">لم يتم تسجيل أي تصريح بعد.</div>
                            </div>
                        }
                        else
                        {
                            <div class="table-responsive">
                                <table class="table table-sm table-borderless mb-0">
                                    <tbody>
                                        <tr class="border-bottom">
                                            <td class="text-muted fw-semibold" style="width:50%">رقم التصريح</td>
                                            <td>
                                                <span class="badge bg-primary fs-6">@declaration.Number</span>
                                            </td>
                                        </tr>
                                        <tr class="border-bottom">
                                            <td class="text-muted fw-semibold">تاريخ التصريح</td>
                                            <td>
                                                <span class="badge bg-light text-dark border fs-6">
                                                    📅 @declaration.RedevableInfo.DateDeclaration.ToString("yyyy/MM/dd")
                                                </span>
                                            </td>
                                        </tr>
                                        <tr class="border-bottom">
                                            <td class="text-muted fw-semibold">كيفية التسديد</td>
                                            <td>
                                                @if (declaration.DafaaWahida)
                                                {
                                                    <span class="badge bg-success fs-6">💵 دفعة واحدة</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-warning text-dark fs-6">
                                                        📅 على أقساط (@declaration.Versements.Count قسط)
                                                    </span>
                                                }
                                            </td>
                                        </tr>
                                        <tr class="border-bottom">
                                            <td class="text-muted fw-semibold">الحقوق البسيطة</td>
                                            <td class="fw-bold">@Fmt(declaration.Droit)</td>
                                        </tr>
                                        <tr class="border-bottom">
                                            <td class="text-muted fw-semibold">غرامات الوعاء</td>
                                            <td class="text-warning fw-semibold">@Fmt(declaration.PA)</td>
                                        </tr>
                                        <tr class="border-bottom">
                                            <td class="text-muted fw-semibold">غرامات التحصيل</td>
                                            <td class="text-warning fw-semibold">@Fmt(declaration.PR)</td>
                                        </tr>
                                        <tr class="border-bottom" style="background:rgba(13,110,253,0.06)">
                                            <td class="fw-bold">المبلغ الإجمالي</td>
                                            <td class="fw-bold text-danger fs-6">@Fmt(declaration.MontantTotal)</td>
                                        </tr>
                                        <tr class="border-bottom" style="background:rgba(13,110,253,0.06)">
                                            <td class="fw-bold">المتبقي (70%)</td>
                                            <td class="fw-bold text-success fs-6">@Fmt(declaration.MontantRestant)</td>
                                        </tr>
                                        <tr style="background:rgba(13,110,253,0.06)">
                                            <td class="text-muted fw-semibold">التخفيض (30%)</td>
                                            <td class="fw-semibold" style="color:#6f42c1">
                                                @Fmt(declaration.Droit * 0.30m)
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        @* ══ Versements table (أقساط only) ════════════════════════════════════ *@
        @if (declaration is { AlaAqsat: true } && declaration.Versements.Any())
        {
            <div class="col-12">
                <div class="card shadow-sm border-0">
                    <div class="card-header fw-semibold bg-warning text-dark">
                        📅 جدول الأقساط
                        <span class="badge bg-dark ms-2">@declaration.Versements.Count قسط</span>
                    </div>
                    <div class="card-body p-0">
                        <table class="table table-hover table-sm mb-0 align-middle text-center">
                            <thead class="table-light">
                                <tr>
                                    <th style="width:50px;">#</th>
                                    <th>تاريخ الاستحقاق</th>
                                    <th>المبلغ (دج)</th>
                                    <th>رقم الوصل</th>
                                    <th>تاريخ الدفع</th>
                                    <th>الحالة</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var v in declaration.Versements.OrderBy(v => v.NumeroOrdre))
                                {
                                    var isPaid = v.EstPaye;
                                    var isDue = !isPaid;
                                    var isLate = v.DatePrevue.Date < DateTime.Today && !isPaid;
                                    var isPaying = payingVersementId == v.Id;

                                    <tr class="@(isLate ? "table-danger" : isPaid ? "table-success" : "")">
                                        <td class="fw-bold">@v.NumeroOrdre</td>
                                        <td>@v.DatePrevue.ToString("dd/MM/yyyy")</td>
                                        <td class="fw-semibold">@Fmt(v.Montant)</td>
                                        <td>
                                            @if (isPaid)
                                            {
                                                <span class="badge bg-success">@v.NumeroQuittance</span>
                                            }
                                            else
                                            {

                                                <span class="text-muted">—</span>
                                            }
                                        </td>
                                        <td>
                                            @if (v.DatePaiement.HasValue)
                                            {
                                                @v.DatePaiement.Value.ToString("dd/MM/yyyy")
                                            }
                                            else
                                            {

                                                <span class="text-muted">—</span>
                                            }
                                        </td>
                                        <td>
                                            @if (isPaid)
                                            {
                                                <span class="badge bg-success">✅ مدفوع</span>
                                            }
                                            else if (isLate)
                                            {
                                                <span class="badge bg-danger">⚠️ متأخر</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">⏳ قيد الانتظار</span>
                                            }
                                        </td>
                                        <td>
                                            @if (isDue && !isPaying)
                                            {
                                                <button class="btn btn-sm btn-primary"
                                                        @onclick="() => StartPay(v.Id)">
                                                    💳 دفع
                                                </button>
                                            }
                                            else if (isPaying)
                                            {
                                                <button class="btn btn-sm btn-outline-secondary"
                                                        @onclick="CancelPay">
                                                    ✕
                                                </button>
                                            }
                                        </td>
                                    </tr>

                                    @if (isPaying)
                                    {
                                        <tr class="table-info">
                                            <td colspan="7">
                                                <div class="d-flex align-items-end gap-3 p-2 flex-wrap">
                                                    <div>
                                                        <label class="form-label small mb-1">
                                                            رقم الوصل <span class="text-danger">*</span>
                                                        </label>
                                                        <input class="form-control form-control-sm"
                                                               style="min-width:180px;"
                                                               placeholder="Q-2026-001"
                                                               @bind="payQuittance" />
                                                    </div>
                                                    <div>
                                                        <label class="form-label small mb-1">تاريخ الدفع</label>
                                                        <input type="date" class="form-control form-control-sm"
                                                               @bind="payDate" />
                                                    </div>
                                                    <button class="btn btn-success btn-sm"
                                                            disabled="@string.IsNullOrWhiteSpace(payQuittance)"
                                                            @onclick="ConfirmPay">
                                                        ✅ تأكيد الدفع
                                                    </button>
                                                    <button class="btn btn-outline-secondary btn-sm"
                                                            @onclick="CancelPay">
                                                        ❌ إلغاء
                                                    </button>
                                                    @if (!string.IsNullOrEmpty(payError))
                                                    {
                                                        <span class="text-danger small">@payError</span>
                                                    }
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                            <tfoot class="table-secondary fw-bold">
                                <tr>
                                    <td colspan="2" class="text-end">المجموع</td>
                                    <td>@Fmt(declaration.Versements.Sum(v => v.Montant))</td>
                                    <td colspan="4"></td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            </div>
        }

        @* ══ DG Decision card ═════════════════════════════════════════════════ *@
        @if (declaration is not null)
        {
            <div class="col-12">
                <div class="card shadow-sm border-2 @DGCardBorder">
                    <div class="card-header fw-semibold @DGCardHeader text-white
                                        d-flex justify-content-between align-items-center">
                        <span>⚖️ قرار المدير العام</span>
                        <span class="badge bg-white @DGBadgeText fs-6">@DGDecisionLabel</span>
                    </div>
                    <div class="card-body">

                        @if (declaration.DGDecision != DGDecisionStatus.EnAttente)
                        {
                            <dl class="row mb-0">
                                <dt class="col-md-3">القرار</dt>
                                <dd class="col-md-9">
                                    @if (declaration.DGDecision == DGDecisionStatus.Acceptee)
                                    {
                                        <span class="badge bg-success fs-6">✅ مقبول</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger fs-6">❌ مرفوض</span>
                                    }
                                </dd>

                                <dt class="col-md-3">تاريخ القرار</dt>
                                <dd class="col-md-9">
                                    @declaration.DGDecisionDate?.ToString("dd/MM/yyyy")
                                </dd>

                                <dt class="col-md-3">رقم القرار</dt>
                                <dd class="col-md-9 fw-semibold">
                                    @declaration.DGDecisionReference
                                </dd>

                                @if (!string.IsNullOrWhiteSpace(declaration.DGDecisionNote))
                                {
                                    <dt class="col-md-3">ملاحظات</dt>
                                    <dd class="col-md-9">@declaration.DGDecisionNote</dd>
                                }

                                @if (declaration.DGDecision == DGDecisionStatus.Acceptee)
                                {
                                    <dt class="col-md-3 border-top pt-2">إلغاء غ. الوعاء (PA)</dt>
                                    <dd class="col-md-9 border-top pt-2 text-success fw-bold">
                                        @Fmt(declaration.AlghaPA)
                                    </dd>
                                    <dt class="col-md-3">إلغاء غ. التحصيل (PR)</dt>
                                    <dd class="col-md-9 text-success fw-bold">
                                        @Fmt(declaration.AlghaPR)
                                    </dd>
                                    <dt class="col-md-3 fw-bold">إجمالي الإلغاء</dt>
                                    <dd class="col-md-9 fw-bold text-success fs-5">
                                        @Fmt(declaration.AlghaPA + declaration.AlghaPR)
                                    </dd>
                                }
                            </dl>

                            <button class="btn btn-sm btn-outline-secondary mt-3"
                                    @onclick="() => dgEditing = true">
                                ✏️ تعديل القرار
                            </button>
                        }

                        @if (declaration.DGDecision == DGDecisionStatus.EnAttente || dgEditing)
                        {
                            <div class="row g-3">
                                <div class="col-12">
                                    <label class="form-label fw-semibold">القرار</label>
                                    <div class="d-flex gap-4">
                                        <div class="form-check">
                                            <input class="form-check-input" type="radio"
                                                   name="dgDecision" id="dgAccept"
                                                   checked="@(dgDecision == DGDecisionStatus.Acceptee)"
                                                   @onchange="() => dgDecision = DGDecisionStatus.Acceptee" />
                                            <label class="form-check-label text-success fw-semibold"
                                                   for="dgAccept">✅ مقبول</label>
                                        </div>
                                        <div class="form-check">
                                            <input class="form-check-input" type="radio"
                                                   name="dgDecision" id="dgRefuse"
                                                   checked="@(dgDecision == DGDecisionStatus.Refusee)"
                                                   @onchange="() => dgDecision = DGDecisionStatus.Refusee" />
                                            <label class="form-check-label text-danger fw-semibold"
                                                   for="dgRefuse">❌ مرفوض</label>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-md-4">
                                    <label class="form-label">
                                        تاريخ القرار <span class="text-danger">*</span>
                                    </label>
                                    <input type="date" class="form-control" @bind="dgDecisionDate" />
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">
                                        رقم القرار <span class="text-danger">*</span>
                                    </label>
                                    <input class="form-control" placeholder="DG-2026-001"
                                           @bind="dgDecisionReference" />
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">ملاحظات</label>
                                    <input class="form-control" placeholder="سبب القرار..."
                                           @bind="dgDecisionNote" />
                                </div>

                                @if (dgDecision == DGDecisionStatus.Acceptee)
                                {
                                    <div class="col-12">
                                        <div class="alert alert-success py-2 mb-0 d-flex gap-4 align-items-center flex-wrap">
                                            <span>⚖️ سيتم إلغاء الغرامات تلقائياً عند الحفظ:</span>
                                            <span>غ. الوعاء: <strong>@Fmt(declaration.PA)</strong></span>
                                            <span>غ. التحصيل: <strong>@Fmt(declaration.PR)</strong></span>
                                            <span class="ms-auto fw-bold text-success fs-6">
                                                الإجمالي: @Fmt(declaration.PA + declaration.PR)
                                            </span>
                                        </div>
                                    </div>
                                }

                                @if (!string.IsNullOrEmpty(dgError))
                                {
                                    <div class="col-12">
                                        <div class="alert alert-danger py-2">⚠️ @dgError</div>
                                    </div>
                                }

                                <div class="col-12 d-flex gap-2">
                                    <button class="btn btn-primary"
                                            disabled="@(dgSaving || string.IsNullOrWhiteSpace(dgDecisionReference))"
                                            @onclick="SaveDGDecision">
                                        @if (dgSaving)
                                        {
                                            <span class="spinner-border spinner-border-sm me-1"></span>
                                        }
                                        💾 حفظ القرار
                                    </button>
                                    @if (dgEditing)
                                    {
                                        <button class="btn btn-outline-secondary"
                                                @onclick="() => dgEditing = false">
                                            ❌ إلغاء
                                        </button>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }

        @* ══ Add / Edit Impot form ════════════════════════════════════════════ *@
        <div class="col-12">
            <div class="card shadow-sm border-0 @(declaration is not null ? "opacity-50" : "")">
                <div class="card-header fw-semibold text-white"
                     style="background:@(declaration is not null ? "#6c757d" : editMode ? "linear-gradient(135deg,#f6a800,#e67e00)" : "linear-gradient(135deg,#0d6efd,#0a58ca)");">
                    @if (declaration is not null)
                    {
                        <span>🔒 إضافة ضريبة — مسجل مسبقاً، التعديل غير مسموح</span>
                    }
                    else if (editMode)
                    {
                        <span>✏️ تعديل الضريبة</span>
                    }
                    else
                    {
                        <span>➕ إضافة ضريبة</span>
                    }
                </div>
                <div class="card-body">
                    @if (declaration is not null)
                    {
                        <div class="alert alert-warning mb-0">
                            ⚠️ هذا المكلف مسجل في السجل برقم التصريح
                            <strong>@declaration.Number</strong>.
                            لا يمكن إضافة أو تعديل الضرائب بعد التسجيل.
                        </div>
                    }
                    else
                    {
                        <div class="row g-3">
                            <div class="col-md-3">
                                <label class="form-label fw-semibold">طبيعة الضريبة</label>
                                <select class="form-select" @bind="currentImpot.NatureImpotId">
                                    <option value="">-- اختر النوع --</option>
                                    @foreach (var n in natures)
                                    {
                                        <option value="@n.Id">@n.Name</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-2">
                                <label class="form-label fw-semibold">السنة</label>
                                <input type="number" class="form-control"
                                       placeholder="2024"
                                       @bind="currentImpot.YearImpot" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label fw-semibold">رقم الدور</label>
                                <input class="form-control"
                                       placeholder="R-2024-001"
                                       @bind="currentImpot.RoleNumber" />
                            </div>
                            <div class="col-md-2">
                                <label class="form-label fw-semibold">الحقوق</label>
                                <CurrencyInput @bind-Value="currentImpot.Droit" />
                            </div>
                            <div class="col-md-2">
                                <label class="form-label fw-semibold">غ. الوعاء</label>
                                <CurrencyInput @bind-Value="currentImpot.PA" />
                            </div>
                            <div class="col-md-2">
                                <label class="form-label fw-semibold">غ. التحصيل</label>
                                <CurrencyInput @bind-Value="currentImpot.PR" />
                            </div>
                            <div class="col-md-3 d-flex align-items-end gap-2">
                                <button class="btn btn-success flex-fill" @onclick="SaveImpot">
                                    @(editMode ? "💾 تحديث" : "➕ إضافة")
                                </button>
                                @if (editMode)
                                {
                                    <button class="btn btn-outline-secondary flex-fill"
                                            @onclick="CancelEdit">
                                        ❌ إلغاء
                                    </button>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        @* ══ Impots table ═════════════════════════════════════════════════════ *@
        <div class="col-12">
            <div class="card shadow-sm border-0">
                <div class="card-header fw-semibold text-white"
                     style="background:linear-gradient(135deg,#1a1a2e,#2c2c54);">
                    🧾 قائمة الضرائب
                </div>
                <div class="card-body p-0">
                    @if (!redevable.Impots.Any())
                    {
                        <div class="p-4 text-muted text-center fst-italic">
                            لا توجد ضرائب مسجلة.
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover table-sm mb-0 text-center align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th>طبيعة الضريبة</th>
                                        <th>السنة</th>
                                        <th>رقم الدور</th>
                                        <th>الحقوق</th>
                                        <th>غ. الوعاء</th>
                                        <th>غ. التحصيل</th>
                                        <th>المجموع</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var i in redevable.Impots)
                                    {
                                        <tr>
                                            <td>@i.NatureImpot?.Name</td>
                                            <td>@i.YearImpot</td>
                                            <td>@i.RoleNumber</td>
                                            <td class="fw-bold">@Fmt(i.Droit)</td>
                                            <td class="text-warning fw-semibold">@Fmt(i.PA)</td>
                                            <td class="text-danger fw-semibold">@Fmt(i.PR)</td>
                                            <td class="text-primary fw-bold">
                                                @Fmt(i.Droit + i.PA + i.PR)
                                            </td>
                                            <td>
                                                @if (declaration is null)
                                                {
                                                    <div class="d-flex gap-1 justify-content-center">
                                                        <button class="btn btn-sm btn-outline-warning"
                                                                @onclick="() => EditImpot(i)">
                                                            ✏️
                                                        </button>
                                                        <button class="btn btn-sm btn-outline-danger"
                                                                @onclick="() => DeleteImpot(i.Id)">
                                                            🗑
                                                        </button>
                                                    </div>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">🔒</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                                <tfoot class="table-secondary fw-bold">
                                    <tr>
                                        <td colspan="3" class="text-end">المجموع الإجمالي</td>
                                        <td>@Fmt(redevable.Impots.Sum(i => i.Droit))</td>
                                        <td class="text-warning">@Fmt(redevable.Impots.Sum(i => i.PA))</td>
                                        <td class="text-danger">@Fmt(redevable.Impots.Sum(i => i.PR))</td>
                                        <td class="text-primary">
                                            @Fmt(redevable.Impots.Sum(i => i.Droit + i.PA + i.PR))
                                        </td>
                                        <td></td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>

    </div>
}

@code {
    [Parameter] public int Id { get; set; }

    RedevableInfo? redevable;
    Declaration? declaration;
    List<NatureImpot> natures = [];

    Impot currentImpot = new();
    bool editMode = false;

    protected override async Task OnInitializedAsync()
    {
        natures = await NatureService.GetAllAsync();
        await Load();
    }

    async Task Load()
    {
        var all = await RedevableService.GetAllAsync();
        redevable = all.FirstOrDefault(x => x.Id == Id);

        var decls = await DeclarationService.GetAllAsync();
        declaration = decls.FirstOrDefault(d => d.RedevableInfoId == Id);
    }

    // ── Impot CRUD ─────────────────────────────────────────────────────────────
    async Task SaveImpot()
    {
        if (declaration is not null) return;
        if (editMode)
            await ImpotService.UpdateAsync(currentImpot);
        else
        {
            currentImpot.RedevableInfoId = Id;
            await ImpotService.AddAsync(currentImpot);
        }
        currentImpot = new Impot();
        editMode = false;
        await Load();
    }

    void EditImpot(Impot i)
    {
        if (declaration is not null) return;
        currentImpot = new Impot
        {
            Id = i.Id,
            RoleNumber = i.RoleNumber,
            YearImpot = i.YearImpot,
            PA = i.PA,
            PR = i.PR,
            Droit = i.Droit,
            NatureImpotId = i.NatureImpotId,
            RedevableInfoId = i.RedevableInfoId
        };
        editMode = true;
    }

    async Task DeleteImpot(int id)
    {
        if (declaration is not null) return;
        await ImpotService.DeleteAsync(id);
        await Load();
    }

    void CancelEdit() { currentImpot = new Impot(); editMode = false; }

    // ── Payment ────────────────────────────────────────────────────────────────
    int? payingVersementId = null;
    string payQuittance = string.Empty;
    DateTime payDate = DateTime.Today;
    string payError = string.Empty;

    void StartPay(int versementId)
    {
        payingVersementId = versementId;
        payQuittance = string.Empty;
        payDate = DateTime.Today;
        payError = string.Empty;
    }

    void CancelPay() { payingVersementId = null; payError = string.Empty; }

    async Task ConfirmPay()
    {
        if (payingVersementId is null) return;
        if (string.IsNullOrWhiteSpace(payQuittance)) { payError = "رقم الوصل مطلوب."; return; }
        try
        {
            await DeclarationService.PayVersementAsync(
                payingVersementId.Value, payQuittance, payDate);
            payingVersementId = null;
            payError = string.Empty;
            await Load();
        }
        catch (Exception ex) { payError = ex.Message; }
    }

    // ── DG Decision ────────────────────────────────────────────────────────────
    DGDecisionStatus dgDecision = DGDecisionStatus.Acceptee;
    DateTime dgDecisionDate = DateTime.Today;
    string dgDecisionReference = string.Empty;
    string dgDecisionNote = string.Empty;
    bool dgSaving = false;
    bool dgEditing = false;
    string dgError = string.Empty;

    async Task SaveDGDecision()
    {
        if (declaration is null) return;
        if (string.IsNullOrWhiteSpace(dgDecisionReference))
        { dgError = "رقم القرار مطلوب."; return; }

        dgSaving = true;
        dgError = string.Empty;
        try
        {
            await DeclarationService.ApplyDGDecisionAsync(
                declaration.Id, dgDecision, dgDecisionDate,
                dgDecisionReference, dgDecisionNote,
                alghaPA: dgDecision == DGDecisionStatus.Acceptee ? declaration.PA : 0,
                alghaPR: dgDecision == DGDecisionStatus.Acceptee ? declaration.PR : 0);
            dgEditing = false;
            await Load();
        }
        catch (Exception ex) { dgError = ex.Message; }
        finally { dgSaving = false; }
    }

    // ── DG styling ─────────────────────────────────────────────────────────────
    string DGCardBorder => declaration?.DGDecision switch
    {
        DGDecisionStatus.Acceptee => "border-success",
        DGDecisionStatus.Refusee => "border-danger",
        _ => "border-warning"
    };

    string DGCardHeader => declaration?.DGDecision switch
    {
        DGDecisionStatus.Acceptee => "bg-success",
        DGDecisionStatus.Refusee => "bg-danger",
        _ => "bg-warning text-dark"
    };

    string DGBadgeText => declaration?.DGDecision switch
    {
        DGDecisionStatus.Acceptee => "text-success",
        DGDecisionStatus.Refusee => "text-danger",
        _ => "text-warning"
    };

    string DGDecisionLabel => declaration?.DGDecision switch
    {
        DGDecisionStatus.Acceptee => "مقبول ✅",
        DGDecisionStatus.Refusee => "مرفوض ❌",
        _ => "⏳ في انتظار القرار"
    };

    // ── Format ─────────────────────────────────────────────────────────────────
    static string Fmt(decimal v) =>
        v == 0 ? "—" :
        string.Format("{0:N0}", Math.Round(v, 0, MidpointRounding.AwayFromZero))
              .Replace(",", "\u00A0") + ",00";
}
