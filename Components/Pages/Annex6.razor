@page "/annex6"
@using ART122.Data
@using ART122.Services
@inject IDeclarationService DeclarationService
@inject IJSRuntime JS

<div class="d-flex justify-content-between align-items-center mb-3 d-print-none">
    <a href="/redevables" class="btn btn-outline-secondary btn-sm">← Retour</a>
    <div class="d-flex gap-2">
        @if (pending?.Any() == true)
        {
            <button class="btn btn-success btn-sm" @onclick="ConfirmSend"
                    disabled="@sending">
                @if (sending)
                {
                    <span class="spinner-border spinner-border-sm me-1"></span>
                }
                ✅ تسجيل الإرسال إلى المديرية
            </button>
            <button class="btn btn-success btn-sm" @onclick="ExportExcel"
                    disabled="@exportingExcel">
                @if (exportingExcel)
                {
                    <span class="spinner-border spinner-border-sm me-1"></span>
                }
                📊 تصدير Excel
            </button>
            <button class="btn btn-primary btn-sm" @onclick="ExportPdf"
                    disabled="@exporting">
                @if (exporting)
                {
                    <span class="spinner-border spinner-border-sm me-1"></span>
                }
                📄 طباعة الملحق 06
            </button>
        }
    </div>
</div>

@if (!string.IsNullOrEmpty(successMsg))
{
    <div class="alert alert-success alert-dismissible d-print-none">
        @successMsg
        <button type="button" class="btn-close" @onclick="() => successMsg = string.Empty"></button>
    </div>
}

@* ══ PRINTABLE CONTENT ══════════════════════════════════════════════════ *@
<div id="annex6-content" dir="rtl"
     style="background:white;padding:20px;font-family:'Arial',sans-serif;">

    <div class="text-center mb-2">
        <div style="font-weight:bold;font-size:1.05rem;">
            الجمهورية الجزائرية الديمقراطية الشعبية
        </div>
        <div style="font-weight:bold;">وزارة المالية — المديرية العامة للضرائب</div>
    </div>

    <div style="display:flex;justify-content:space-between;margin-bottom:6px;font-size:.85rem;">
        <div>مديرية: الوادي</div>
        <div>قباضة الضرائب لـ: المركز الجواري الدبيلة</div>
    </div>

    <div style="text-align:center;font-weight:bold;border:2px solid black;
                padding:8px;margin-bottom:16px;">
        الجدول الإسمي الجماعي للتصريحات بالاكتتاب<br />
        في إجراء تطهير الديون الجبائية<br />
        <span style="font-size:.85rem;">(المادة 122 من قانون المالية لسنة 2026)</span>
    </div>

    @if (pending == null)
    {
        <div>جارٍ التحميل...</div>
    }
    else if (!pending.Any())
    {
        <div class="alert alert-info d-print-none">
            ✅ لا توجد تصريحات جديدة في انتظار الإرسال. جميع التصريحات تم تسجيلها مسبقاً.
        </div>
    }
    else
    {
        <table style="width:100%;border-collapse:collapse;font-size:.75rem;text-align:center;">
            <thead>
                <tr style="background:#222;color:white;">
                    <th style="@th;width:36px;">رقم<br />الترتيب (*)</th>
                    <th style="@th;">الاسم / اللقب أو التسمية الاجتماعية</th>
                    <th style="@th;width:90px;">المبلغ الكلي<br />للدين الجبائي</th>
                    <th style="@th;width:90px;">الحقوق البسيطة<br />المستحقة (70%)</th>
                    <th style="@th;width:80px;">غرامات<br />الوعاء</th>
                    <th style="@th;width:80px;">غرامات<br />التحصيل</th>
                    <th style="@th;width:80px;">مبلغ<br />التخفيض (30%)</th>
                    <th style="@th;width:44px;">طريقة<br />تسوية الدين (**)</th>
                    <th style="@th;">ملاحظات</th>
                    <th style="@th;">رقم وتاريخ<br />مقرر الإلغاء</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var d in pending)
                {
                    var reduction = Math.Round(d.Droit * 0.30m, 0, MidpointRounding.AwayFromZero);
                    <tr style="border-bottom:1px solid #ccc;">
                        <td style="@td;">@d.Number</td>
                        <td style="@td;text-align:right;">@d.RedevableInfo.FullName</td>
                        <td style="@td;">@Fmt(d.MontantTotal)</td>
                        <td style="@td;">@Fmt(d.MontantRestant)</td>
                        <td style="@td;">@Fmt(d.PA)</td>
                        <td style="@td;">@Fmt(d.PR)</td>
                        <td style="@td;">@Fmt(reduction)</td>
                        <td style="@td;font-weight:bold;">@(d.DafaaWahida ? "ك" : "ق")</td>
                        <td style="@td;"></td>
                        <td style="@td;"></td>
                    </tr>
                }
                <tr style="background:#f0f0f0;font-weight:bold;border-top:2px solid #333;">
                    <td colspan="2" style="@td;text-align:right;">المجموع</td>
                    <td style="@td;">@Fmt(pending.Sum(d => d.MontantTotal))</td>
                    <td style="@td;">@Fmt(pending.Sum(d => d.MontantRestant))</td>
                    <td style="@td;">@Fmt(pending.Sum(d => d.PA))</td>
                    <td style="@td;">@Fmt(pending.Sum(d => d.PR))</td>
                    <td style="@td;">
                        @Fmt(pending.Sum(d =>
                        Math.Round(d.Droit * 0.30m, 0, MidpointRounding.AwayFromZero)))
                </td>
                <td colspan="3" style="@td;"></td>
            </tr>
        </tbody>
    </table>

    <div style="font-size:.72rem;margin-top:8px;">
        (*) رقم الترتيب الواجب تسجيله في التصريح بالاكتتاب<br />
        (**) طريقة تسوية الدين: كليا (ك) أو على أقساط (ق)
    </div>

    <div style="display:flex;justify-content:space-between;margin-top:30px;font-size:.82rem;">
        <div>
            حررت بـ: المركز الجواري الدبيلة &nbsp;&nbsp;
            في: @DateTime.Today.ToString("dd/MM/yyyy")
        </div>
        <div style="text-align:center;">
            قابض الضرائب:<br /><br /><br />
            (الإمضاء والختم)
        </div>
    </div>

    <div style="text-align:left;margin-top:10px;font-size:.7rem;color:#666;">
        الملحق 06
    </div>
        }
</div>

