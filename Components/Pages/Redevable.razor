@page "/redevables"
@using ART122.Data
@using ART122.Services
@inject IRedevableService RedevableService
@inject IDeclarationService DeclarationService
@inject IArt122PdfService PdfService
@inject IJSRuntime JS
@inject NavigationManager Nav

<h4 class="mb-0 fw-bold mb-5 text-center">📋 قائمة المكلفين</h4>
<div class="d-flex justify-content-between align-items-center mb-4">

    <a href="/redevable-create" class="btn btn-primary btn-sm w-25">
        <span class="bi bi-plus-square-fill-nav-menu" aria-hidden="true"></span> إدراج مكلف جديد 
    </a>
    <a href="/annex5" class="btn btn-outline-primary btn-sm">
        📋 سجل الملحق 05
    </a>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body">

        <div class="mb-3">
            <label class="form-label fw-semibold">🔍 البحث برقم BP</label>
            <input class="form-control"
                   placeholder="أدخل رقم BP..."
                   value="@searchBp"
                   @oninput="OnSearchChanged" />
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-info text-center">
                    <tr>
                        <th>BP</th>
                        <th>الاسم الكامل</th>
                        <th>العنوان</th>
                        <th>NIF</th>
                        <th>الإجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in filtered ?? [])
                    {
                        var alreadyRegistered = registeredIds.Contains(r.Id);
                        <tr>
                            <td class="fw-bold text-center">@r.BP</td>
                            <td>@r.FullName</td>
                            <td class="text-muted small">@r.Adresse</td>
                            <td class="text-center">@r.NIF</td>
                            <td>
                                <div class="d-flex gap-2 flex-wrap justify-content-center">

                                    <button class="btn btn-sm btn-outline-info"
                                            style="min-width:110px;"
                                            @onclick="() => ToggleExpand(r.Id)">
                                        @(expandedId == r.Id ? "🔼 إخفاء" : "🔽 الضرائب")
                                    </button>

                                    <button class="btn btn-sm btn-outline-warning"
                                            style="min-width:110px;"
                                            @onclick="() => Edit(r)">
                                        ✏️ تعديل
                                    </button>

                                    <button class="btn btn-sm btn-outline-danger"
                                            style="min-width:110px;"
                                            @onclick="() => ConfirmDelete(r)">
                                        🗑 حذف
                                    </button>

                                    <a class="btn btn-sm btn-outline-dark"
                                       style="min-width:110px;"
                                       href="/redevable-details/@r.Id">
                                        👁 التفاصيل
                                    </a>

                                    @if (alreadyRegistered)
                                    {
                                        <button class="btn btn-sm btn-success"
                                                style="min-width:110px;"
                                                disabled title="مسجل مسبقاً">
                                            ✅ مسجل
                                        </button>

                                        <button class="btn btn-sm btn-outline-secondary"
                                                style="min-width:110px;"
                                                disabled="@(printingPdfId == r.Id)"
                                                @onclick="() => PrintExistingPdf(r)">
                                            @if (printingPdfId == r.Id)
                                            {
                                                <span class="spinner-border spinner-border-sm me-1"></span>
                                            }
                                            🖨 طباعة
                                        </button>
                                    }
                                    else
                                    {
                                        <button class="btn btn-sm btn-primary"
                                                style="min-width:110px;"
                                                @onclick="() => OpenPrintModal(r)">
                                            📝 تسجيل الطلب
                                        </button>
                                    }

                                </div>
                            </td>
                        </tr>

                        @if (expandedId == r.Id)
                        {
                            <tr class="table-light">
                                <td colspan="5" class="p-3">
                                    @if (r.Impots == null || !r.Impots.Any())
                                    {
                                        <div class="text-muted text-center py-2">
                                            لا توجد ضرائب مسجلة
                                        </div>
                                    }
                                    else
                                    {
                                        <table class="table table-sm table-bordered mb-0">
                                            <thead class="table-secondary text-center">
                                                <tr>
                                                    <th>طبيعة الضريبة</th>
                                                    <th>السنة</th>
                                                    <th>رقم الجدول</th>
                                                    <th>الحقوق</th>
                                                    <th>غ. الوعاء</th>
                                                    <th>غ. التحصيل</th>
                                                </tr>
                                            </thead>
                                            <tbody class="text-center">
                                                @foreach (var imp in r.Impots)
                                                {
                                                    <tr>
                                                        <td>@imp.NatureImpot?.Name</td>
                                                        <td>@imp.YearImpot</td>
                                                        <td>@imp.RoleNumber</td>
                                                        <td class="fw-bold">@imp.Droit</td>
                                                        <td class="text-warning">@imp.PA</td>
                                                        <td class="text-danger">@imp.PR</td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@* ══ Print Modal ══════════════════════════════════════════════════════════════ *@
@if (showPrintModal && printTarget != null)
{
    <div class="modal fade show d-block" tabindex="-1"
         style="background:rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg">
            <div class="modal-content border-0 shadow">

                <div class="modal-header text-white"
                     style="background:linear-gradient(135deg,#1a1a2e,#2c2c54);">
                    <h5 class="modal-title">🖨 تصريح الاكتتاب — المادة 122</h5>
                    <button class="btn-close btn-close-white"
                            @onclick="ClosePrintModal"></button>
                </div>

                <div class="modal-body">

                    <div class="alert alert-light border-start border-4 border-primary py-2 mb-3">
                        <div class="fw-bold">@printTarget.FullName</div>
                        <div class="text-muted small">
                            BP: @printTarget.BP — NIF: @printTarget.NIF
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(printError))
                    {
                        <div class="alert alert-danger">⚠️ @printError</div>
                    }

                    <label class="form-label fw-semibold">كيفية التسديد:</label>
                    <div class="d-flex gap-3 mb-3">
                        <div class="form-check">
                            <input class="form-check-input" type="radio"
                                   name="payMode" id="rdDafaa"
                                   checked="@printDafaaWahida"
                                   @onchange="() => SetPayMode(true)" />
                            <label class="form-check-label" for="rdDafaa">
                                💵 دفعة واحدة
                            </label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="radio"
                                   name="payMode" id="rdAqsat"
                                   checked="@(!printDafaaWahida)"
                                   @onchange="() => SetPayMode(false)" />
                            <label class="form-check-label" for="rdAqsat">
                                📅 على أقساط
                            </label>
                        </div>
                    </div>

                    @if (!printDafaaWahida)
                    {
                        <div class="card border-primary mb-3">
                            <div class="card-header bg-primary text-white fw-semibold py-2">
                                📅 جدول الأقساط
                            </div>
                            <div class="card-body">
                                <div class="row align-items-end mb-3 g-2">
                                    <div class="col-md-4">
                                        <label class="form-label small fw-semibold">
                                            عدد الأقساط
                                            <span class="text-muted fw-normal">(آخر قسط ≤ 31/12/2026)</span>
                                        </label>
                                        <input type="number" class="form-control"
                                               min="1" max="@MaxDofaa"
                                               value="@nbrDofaa"
                                               @onchange="OnNbrDofaaChanged" />
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label small fw-semibold">المبلغ الإجمالي</label>
                                        <input class="form-control bg-light" readonly
                                               value="@FmtDecimal(printMontantRestant)" />
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label small fw-semibold">قسط واحد (تقريباً)</label>
                                        <input class="form-control bg-light" readonly
                                               value="@FmtDecimal(SingleInstallment)" />
                                    </div>
                                </div>

                                @if (versementRows.Any() &&
                                                        versementRows.Last().DatePrevue > new DateTime(2026, 12, 31))
                                {
                                    <div class="alert alert-danger py-2 small">
                                        ⚠️ آخر قسط يتجاوز 31/12/2026. قلّل عدد الأقساط أو عدّل التواريخ.
                                    </div>
                                }

                                @if (versementRows.Count > 0)
                                {
                                    <table class="table table-sm table-bordered">
                                        <thead class="table-light text-center">
                                            <tr>
                                                <th style="width:50px;">#</th>
                                                <th>تاريخ الاستحقاق</th>
                                                <th>المبلغ (دج)</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @for (int i = 0; i < versementRows.Count; i++)
                                            {
                                                var idx = i;
                                                var row = versementRows[idx];
                                                var dateOver = row.DatePrevue > new DateTime(2026, 12, 31);
                                                <tr class="@(dateOver ? "table-danger" : "")">
                                                    <td class="text-center fw-bold">@(idx + 1)</td>
                                                    <td>
                                                        <input type="date"
                                                               class="form-control form-control-sm @(dateOver ? "is-invalid" : "")"
                                                               value="@row.DatePrevue.ToString("yyyy-MM-dd")"
                                                               max="2026-12-31"
                                                               @onchange="e => OnDateChanged(idx, e)" />
                                                    </td>
                                                    <td>
                                                        <input type="number"
                                                               class="form-control form-control-sm"
                                                               value="@row.Montant"
                                                               @onchange="e => OnMontantChanged(idx, e)" />
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                        <tfoot>
                                            <tr class="table-secondary fw-bold text-center">
                                                <td colspan="2">المجموع</td>
                                                <td>@FmtDecimal(versementRows.Sum(v => v.Montant))</td>
                                            </tr>
                                        </tfoot>
                                    </table>
                                }
                            </div>
                        </div>
                    }

                    @if (printDafaaWahida)
                    {
                        <div class="row g-2 mt-2">
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">رقم الوصل</label>
                                <input class="form-control"
                                       placeholder="رقم الوصل..."
                                       @bind="dafaaNumeroQuittance" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">تاريخ الدفع</label>
                                <input type="date" class="form-control"
                                       @bind="dafaaDatePaiement" />
                            </div>
                        </div>
                    }
                </div>

                <div class="modal-footer">
                    <button class="btn btn-outline-secondary" @onclick="ClosePrintModal">
                        ❌ إلغاء
                    </button>
                    <button class="btn btn-primary"
                            disabled="@(printLoading || HasDateError)"
                            @onclick="ConfirmPrint">
                        @if (printLoading)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                            <span>جارٍ الإنشاء...</span>
                        }
                        else
                        {
                            <span>✅ تسجيل وطباعة</span>
                        }
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@* ══ Edit Modal ═══════════════════════════════════════════════════════════════ *@
@if (showEditModal && editModel != null)
{
    <div class="modal fade show d-block" tabindex="-1"
         style="background:rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg">
            <div class="modal-content border-0 shadow">
                <div class="modal-header text-white"
                     style="background:linear-gradient(135deg,#f6a800,#e67e00);">
                    <h5 class="modal-title">✏️ تعديل بيانات المكلف</h5>
                    <button class="btn-close btn-close-white" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">رقم BP</label>
                            <input class="form-control" @bind="editModel.BP" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">رقم المادة</label>
                            <input class="form-control" @bind="editModel.Article" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">NIF</label>
                            <input class="form-control" @bind="editModel.NIF" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">الاسم الكامل</label>
                            <input class="form-control" @bind="editModel.FullName" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">ابن / بنت</label>
                            <input class="form-control" @bind="editModel.FilsDe" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">العنوان</label>
                            <input class="form-control" @bind="editModel.Adresse" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">المؤسسة</label>
                            <input class="form-control" @bind="editModel.Etablissement" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">الهاتف</label>
                            <input class="form-control" @bind="editModel.Telephone" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">البريد الإلكتروني</label>
                            <input class="form-control" @bind="editModel.Email" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">النشاط</label>
                            <input class="form-control" @bind="editModel.Activite" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-outline-secondary" @onclick="CloseModal">
                        ❌ إلغاء
                    </button>
                    <button class="btn btn-warning fw-semibold" @onclick="UpdateRedevable">
                        💾 حفظ التعديلات
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@* ══ Delete Modal ═════════════════════════════════════════════════════════════  *@
@if (showDeleteModal && toDelete != null)
{
    <div class="modal fade show d-block" tabindex="-1"
         style="background:rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content border-0 shadow">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title">🗑 تأكيد الحذف</h5>
                    <button class="btn-close btn-close-white" @onclick="CancelDelete"></button>
                </div>
                <div class="modal-body">
                    <p>هل أنت متأكد من حذف المكلف التالي؟</p>
                    <div class="alert alert-warning py-2 fw-bold">
                        @toDelete.FullName
                    </div>
                    @if (!string.IsNullOrEmpty(deleteMessage))
                    {
                        <div class="alert alert-danger mt-2">@deleteMessage</div>
                    }
                </div>
                <div class="modal-footer">
                    <button class="btn btn-outline-secondary" @onclick="CancelDelete">
                        ❌ إلغاء
                    </button>
                    <button class="btn btn-danger" @onclick="Delete">
                        🗑 تأكيد الحذف
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {

    int? printingPdfId = null;
    List<RedevableInfo>? redevables;
    List<RedevableInfo>? filtered;
    HashSet<int> registeredIds = [];
    string searchBp = "";

    protected override async Task OnInitializedAsync() => await LoadData();

    async Task LoadData()
    {
        redevables = await RedevableService.GetAllAsync();
        var declarations = await DeclarationService.GetAllAsync();
        registeredIds = declarations.Select(d => d.RedevableInfoId).ToHashSet();
        ApplyFilter();
    }

    void OnSearchChanged(ChangeEventArgs e)
    {
        searchBp = e.Value?.ToString() ?? "";
        ApplyFilter();
    }

    void ApplyFilter()
    {
        filtered = string.IsNullOrWhiteSpace(searchBp)
            ? redevables
            : redevables?.Where(r => r.BP.ToString().Contains(searchBp)).ToList();
    }

    int? expandedId;
    void ToggleExpand(int id) => expandedId = expandedId == id ? null : id;

    // ── Print modal ────────────────────────────────────────────────────────────
    bool showPrintModal = false;
    bool printLoading = false;
    bool printDafaaWahida = true;
    RedevableInfo? printTarget;
    string? printError;
    decimal printMontantRestant = 0;
    int nbrDofaa = 1;
    List<VersementInput> versementRows = [];
    string dafaaNumeroQuittance = string.Empty;
    DateTime dafaaDatePaiement = DateTime.Today;

    static readonly DateTime Deadline = new(2026, 12, 31);

    int MaxDofaa => Math.Max(1,
        ((Deadline.Year - DateTime.Today.Year) * 12)
        + Deadline.Month - DateTime.Today.Month + 1);

    decimal SingleInstallment =>
        nbrDofaa > 0 ? Math.Round(printMontantRestant / nbrDofaa, 0) : 0;

    bool HasDateError =>
        !printDafaaWahida && versementRows.Any(v => v.DatePrevue > Deadline);

    async Task OpenPrintModal(RedevableInfo r)
    {
        printTarget = r;
        printDafaaWahida = true;
        printError = null;
        nbrDofaa = 1;
        versementRows = [];
        dafaaNumeroQuittance = string.Empty;
        dafaaDatePaiement = DateTime.Today;
        printMontantRestant = await DeclarationService.GetMontantRestantAsync(r.Id);
        showPrintModal = true;
    }

    void ClosePrintModal()
    {
        showPrintModal = false;
        printTarget = null;
        printError = null;
        versementRows = [];
        dafaaNumeroQuittance = string.Empty;
        dafaaDatePaiement = DateTime.Today;
    }

    void SetPayMode(bool dafaa)
    {
        printDafaaWahida = dafaa;
        if (!dafaa) BuildRows(); else versementRows = [];
    }

    void OnNbrDofaaChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var n) && n >= 1)
        { nbrDofaa = Math.Min(n, MaxDofaa); BuildRows(); }
    }

    void BuildRows()
    {
        versementRows = [];
        if (nbrDofaa <= 0) return;
        var per = Math.Round(printMontantRestant / nbrDofaa, 0);
        for (int i = 0; i < nbrDofaa; i++)
        {
            var date = DateTime.Today.AddMonths(i);
            var amount = i == nbrDofaa - 1 ? printMontantRestant - per * (nbrDofaa - 1) : per;
            versementRows.Add(new VersementInput
            {
                DatePrevue = date > Deadline ? Deadline : date,
                Montant = amount,
                NumeroQuittance = string.Empty
            });
        }
    }

    void OnDateChanged(int idx, ChangeEventArgs e)
    { if (DateTime.TryParse(e.Value?.ToString(), out var d)) versementRows[idx].DatePrevue = d; }

    void OnMontantChanged(int idx, ChangeEventArgs e)
    { if (decimal.TryParse(e.Value?.ToString(), out var v)) versementRows[idx].Montant = v; }

    async Task ConfirmPrint()
    {
        if (printTarget is null) return;
        printLoading = true;
        printError = null;
        try
        {
            var declaration = await DeclarationService.CreateAsync(
                printTarget.Id,
                dafaaWahida: printDafaaWahida,
                alaAqsat: !printDafaaWahida,
                versements: printDafaaWahida ? null : versementRows,
                numeroQuittance: printDafaaWahida ? dafaaNumeroQuittance : null,
                datePaiement: printDafaaWahida ? dafaaDatePaiement : null);

            registeredIds.Add(printTarget.Id);

            var bytes = await PdfService.FillFromDeclarationAsync(declaration);
            await JS.InvokeVoidAsync("downloadFileFromBase64",
                Convert.ToBase64String(bytes),
                $"art122_n{declaration.Number}_{printTarget.FullName}.pdf",
                "application/pdf");

            showPrintModal = false;
            printTarget = null;
            versementRows = [];
        }
        catch (Exception ex) { printError = ex.Message; }
        finally { printLoading = false; }
    }

    async Task PrintExistingPdf(RedevableInfo r)
    {
        printingPdfId = r.Id;
        StateHasChanged();
        try
        {
            var declaration = await DeclarationService.GetByRedevableIdAsync(r.Id);
            if (declaration is null) { printError = "لم يتم العثور على التصريح."; return; }
            var bytes = await PdfService.FillFromDeclarationAsync(declaration);
            await JS.InvokeVoidAsync("downloadFileFromBase64",
                Convert.ToBase64String(bytes),
                $"art122_n{declaration.Number}_{r.FullName}.pdf",
                "application/pdf");
        }
        catch (Exception ex) { printError = ex.Message; }
        finally { printingPdfId = null; }
    }

    static string FmtDecimal(decimal v) =>
        v == 0 ? "0" : string.Format("{0:N0}", v).Replace(",", "\u00A0") + ",00";

    // ── Edit ───────────────────────────────────────────────────────────────────
    RedevableInfo? editModel;
    bool showEditModal;

    void Edit(RedevableInfo r)
    {
        editModel = new RedevableInfo
        {
            Id = r.Id,
            BP = r.BP,
            Article = r.Article,
            NIF = r.NIF,
            FullName = r.FullName,
            FilsDe = r.FilsDe,
            Adresse = r.Adresse,
            Telephone = r.Telephone,
            Email = r.Email,
            Activite = r.Activite,
            Etablissement = r.Etablissement
        };
        showEditModal = true;
    }

    async Task UpdateRedevable()
    {
        await RedevableService.UpdateAsync(editModel!);
        showEditModal = false;
        editModel = null;
        await LoadData();
    }

    void CloseModal() { showEditModal = false; editModel = null; }

    // ── Delete ─────────────────────────────────────────────────────────────────
    RedevableInfo? toDelete;
    bool showDeleteModal;
    string? deleteMessage;

    void ConfirmDelete(RedevableInfo r) { toDelete = r; showDeleteModal = true; deleteMessage = null; }
    void CancelDelete() { showDeleteModal = false; toDelete = null; deleteMessage = null; }

    async Task Delete()
    {
        var result = await RedevableService.DeleteAsync(toDelete!.Id);
        deleteMessage = result.Message;
        if (result.IsValid) { showDeleteModal = false; toDelete = null; await LoadData(); }
    }
}

<script>
    window.downloadFileFromBase64 = (base64, filename, mimeType) => {
        const a = document.createElement('a');
        a.href = `data:${mimeType};base64,${base64}`;
        a.download = filename;
        a.click();
    };
</script>
