@page "/redevable-create"
@using ART122.Data
@using ART122.Services
@using static ART122.Data.DTOs
@inject IRedevableService RedevableService
@inject INatureImpotService NatureService

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0 fw-bold">➕ تسجيل مكلف جديد</h4>
    <a href="/redevables" class="btn btn-outline-secondary btn-sm">← العودة للقائمة</a>
</div>

<div class="container-fluid px-0">

    @* ══ REDEVABLE FORM ══════════════════════════════════════════════════════ *@
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-header text-white fw-semibold"
             style="background:linear-gradient(135deg,#1a1a2e,#2c2c54);">
            👤 بيانات المكلف
        </div>
        <div class="card-body">
            <div class="row g-3">

                <div class="col-md-4">
                    <label class="form-label fw-semibold">رقم BP</label>
                    <input type="number" class="form-control"
                           placeholder="رقم الشريك التجاري"
                           @bind="model.BP" />
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">رقم المادة</label>
                    <input type="number" class="form-control"
                           placeholder="رقم المادة"
                           @bind="model.Article" />
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">NIF</label>
                    <input type="number" class="form-control"
                           placeholder="رقم التعريف الجبائي"
                           @bind="model.NIF" />
                </div>

                <div class="col-md-6">
                    <label class="form-label fw-semibold">الاسم الكامل</label>
                    <input class="form-control"
                           placeholder="الاسم واللقب"
                           @bind="model.FullName" />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">ابن / بنت</label>
                    <input class="form-control"
                           placeholder="اسم الأب"
                           @bind="model.FilsDe" />
                </div>

                <div class="col-md-6">
                    <label class="form-label fw-semibold">المؤسسة</label>
                    <input class="form-control"
                           placeholder="اسم المؤسسة"
                           @bind="model.Etablissement" />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">العنوان</label>
                    <input class="form-control"
                           placeholder="العنوان الكامل"
                           @bind="model.Adresse" />
                </div>

                <div class="col-md-4">
                    <label class="form-label fw-semibold">الهاتف</label>
                    <input class="form-control"
                           placeholder="رقم الهاتف"
                           @bind="model.Telephone" />
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">البريد الإلكتروني</label>
                    <input class="form-control"
                           placeholder="example@mail.com"
                           @bind="model.Email" />
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">النشاط</label>
                    <input class="form-control"
                           placeholder="طبيعة النشاط"
                           @bind="model.Activite" />
                </div>

            </div>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger mt-3 py-2">
                    ⚠️ @errorMessage
                </div>
            }

            <div class="text-end mt-3">
                <button class="btn btn-primary px-4"
                        @onclick="SaveRedevable"
                        disabled="@isRedevableSaved">
                    @if (isRedevableSaved)
                    {
                        <span>✅ تم حفظ المكلف</span>
                    }
                    else
                    {
                        <span>💾 حفظ المكلف</span>
                    }
                </button>
            </div>
        </div>
    </div>

    @* ══ IMPOT FORM ══════════════════════════════════════════════════════════ *@
    @if (!isRedevableSaved)
    {
        <div class="alert alert-warning d-flex align-items-center gap-2">
            <span style="font-size:1.3rem;">⚠️</span>
            <span>يرجى حفظ بيانات المكلف أولاً قبل إضافة الضرائب.</span>
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-header text-white fw-semibold"
                 style="background:linear-gradient(135deg,#162b52,#2c5282);">
                ➕ إضافة ضريبة
            </div>
            <div class="card-body">
                <div class="row g-3">

                    <div class="col-md-6">
                        <label class="form-label fw-semibold">طبيعة الضريبة</label>
                        <select class="form-select" @bind="newImpot.NatureImpotId">
                            <option value="">-- اختر النوع --</option>
                            @foreach (var n in natures)
                            {
                                <option value="@n.Id">@n.Name</option>
                            }
                        </select>
                    </div>

                    <div class="col-md-3">
                        <label class="form-label fw-semibold">السنة</label>
                        <input type="number" class="form-control"
                               placeholder="مثال: 2024"
                               min="1962" max="2100"
                               @bind="newImpot.YearImpot" />
                    </div>

                    <div class="col-md-3">
                        <label class="form-label fw-semibold">رقم الجدول</label>
                        <input class="form-control"
                               placeholder="R-2024-001"
                               @bind="newImpot.RoleNumber" />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-semibold">الحقوق البسيطة (دج)</label>
                        <input type="number" class="form-control"
                               placeholder="0"
                               @bind="newImpot.Droit" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">غرامات الوعاء (PA)</label>
                        <input type="number" class="form-control"
                               placeholder="0"
                               @bind="newImpot.PA" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">غرامات التحصيل (PR)</label>
                        <input type="number" class="form-control"
                               placeholder="0"
                               @bind="newImpot.PR" />
                    </div>

                    <div class="col-12">
                        <button class="btn btn-success w-100 py-2 fw-semibold"
                                @onclick="AddImpot">
                            ➕ إضافة الضريبة للقائمة
                        </button>
                    </div>

                </div>
            </div>
        </div>

        @* ══ CURRENT IMPOTS TABLE ════════════════════════════════════════════ *@
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-header bg-secondary text-white fw-semibold">
                📊 الضرائب المضافة
            </div>
            <div class="card-body p-0">
                @if (model.Impots.Count == 0)
                {
                    <div class="text-center text-muted py-4">
                        لم يتم إضافة أي ضريبة بعد.
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover mb-0 text-center align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>طبيعة الضريبة</th>
                                    <th>السنة</th>
                                    <th>رقم الجدول</th>
                                    <th>الحقوق</th>
                                    <th>غ. الوعاء</th>
                                    <th>غ. التحصيل</th>
                                    <th>المجموع</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var i in model.Impots)
                                {
                                    <tr>
                                        <td>@(natures.FirstOrDefault(n => n.Id == i.NatureImpotId)?.Name ?? "-")</td>
                                        <td>@i.YearImpot</td>
                                        <td>@i.RoleNumber</td>
                                        <td class="fw-bold">@i.Droit.ToString("N0")</td>
                                        <td class="text-warning fw-semibold">@i.PA.ToString("N0")</td>
                                        <td class="text-danger fw-semibold">@i.PR.ToString("N0")</td>
                                        <td class="text-primary fw-bold">
                                            @((i.Droit + i.PA + i.PR).ToString("N0"))
                                        </td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot class="table-secondary fw-bold">
                                <tr>
                                    <td colspan="3" class="text-end">المجموع الإجمالي</td>
                                    <td>@model.Impots.Sum(i => i.Droit).ToString("N0")</td>
                                    <td class="text-warning">@model.Impots.Sum(i => i.PA).ToString("N0")</td>
                                    <td class="text-danger">@model.Impots.Sum(i => i.PR).ToString("N0")</td>
                                    <td class="text-primary">
                                        @model.Impots.Sum(i => i.Droit + i.PA + i.PR).ToString("N0")
                                    </td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                }
            </div>
        </div>

        @* ══ SAVE ALL ════════════════════════════════════════════════════════ *@
        <div class="d-flex justify-content-between align-items-center">
            <span class="text-muted small">
                @model.Impots.Count ضريبة مضافة
            </span>
            <button class="btn btn-success btn-lg px-5 fw-semibold"
                    disabled="@(model.Impots.Count == 0)"
                    @onclick="SaveAll">
                ✅ حفظ جميع الضرائب
            </button>
        </div>
    }

</div>

@code {

    RedevableCreateDto model = new();
    ImpotCreateDto newImpot = new();
    List<NatureImpot> natures = new();
    string? errorMessage;
    bool isRedevableSaved = false;
    int savedRedevableId;
    string persistedRoleNumber = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        natures = await NatureService.GetAllAsync();
    }

    // ── Save redevable ─────────────────────────────────────────────────────────
    async Task SaveRedevable()
    {
        var check = await RedevableService.ValidateRedevable(
            model.BP, model.NIF, model.Article);

        if (!check.IsValid) { errorMessage = check.Message; return; }

        var result = await RedevableService.Create(model);
        savedRedevableId = result.Id;
        isRedevableSaved = true;
        errorMessage = null;

        newImpot = new ImpotCreateDto { RoleNumber = persistedRoleNumber };
    }

    // ── Add impot locally ──────────────────────────────────────────────────────
    void AddImpot()
    {
        var currentYear = DateTime.Now.Year;

        if (newImpot.YearImpot < 1962 || newImpot.YearImpot > currentYear - 1)
        {
            errorMessage = $"السنة ({newImpot.YearImpot}) غير صحيحة. أدخل سنة بين 1962 و {currentYear - 1}.";
            return;
        }

        errorMessage = null;

        model.Impots.Add(new ImpotCreateDto
        {
            RoleNumber = newImpot.RoleNumber,
            PA = newImpot.PA,
            PR = newImpot.PR,
            Droit = newImpot.Droit,
            NatureImpotId = newImpot.NatureImpotId,
            YearImpot = newImpot.YearImpot
        });

        persistedRoleNumber = newImpot.RoleNumber;
        newImpot = new ImpotCreateDto { RoleNumber = persistedRoleNumber };
    }

    // ── Save all impots ────────────────────────────────────────────────────────
    async Task SaveAll()
    {
        await RedevableService.AddImpots(savedRedevableId, model.Impots);

        persistedRoleNumber = model.Impots.LastOrDefault()?.RoleNumber ?? persistedRoleNumber;

        model = new RedevableCreateDto();
        newImpot = new ImpotCreateDto { RoleNumber = persistedRoleNumber };
        isRedevableSaved = false;
    }
}
